# Frontend API base URL.
# For development, use http://localhost:5000.
# For Vercel, set this to the Railway backend URL.
REACT_APP_API_BASE_URL=http://localhost:5000

# Sepolia JSON-RPC URL for public certificate verification.
# Use an Infura or Alchemy Sepolia RPC URL.
# Do not commit real secrets in this file.
REACT_APP_SEPOLIA_RPC_URL=

# Firebase public web app configuration.
# These values are safe for frontend builds, but keep service account/private
# credentials backend-only.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
